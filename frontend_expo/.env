# Ballife Expo 앱 환경변수 (.env 로 복사해 사용; git 미추적)
# Expo 클라이언트 노출 변수는 EXPO_PUBLIC_ 접두사 필수.
#
# ⚠️ 실기기는 "localhost"가 기기 자신을 가리킴 → PC LAN IP 사용.
#    이 PC 의 Wi-Fi IP: 10.100.0.43 (폰과 같은 Wi-Fi 에 연결돼 있어야 함)
#    IP 가 바뀌면(다른 네트워크) 아래 값을 새 IP 로 수정.

# 이 Wi-Fi 가 기기간 통신(AP 격리)을 막아 LAN(10.100.0.43)으론 폰에서 백엔드에 못 닿음.
# → cloudflared 공개 터널로 백엔드를 노출해 인터넷 경유로 접속.
#   터널 URL 은 cloudflared 재시작 시 매번 바뀌므로, 바뀌면 아래 값을 갱신할 것.
# (직전 LAN 설정: http://10.100.0.43:8080/api)
EXPO_PUBLIC_API_BASE_URL=https://venue-readings-filled-lows.trycloudflare.com/api
EXPO_PUBLIC_AI_SERVICE_BASE_URL=https://womens-resources-florist-total.trycloudflare.com
# Unity WebGL 펫 빌드(frontend/public/Unity) 를 정적 서버(8090)+cloudflared 로 노출한 주소
EXPO_PUBLIC_UNITY_URL=https://activated-namespace-latex-editorials.trycloudflare.com
