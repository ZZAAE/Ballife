# 빌드 컨텍스트에서 제외 — 이미지 용량/빌드 속도 최적화
node_modules
dist
build

# 로컬 환경/비밀값 (운영 API 주소는 Dockerfile 의 --build-arg 로 주입)
.env
.env.*
!.env.example

# VCS / 에디터 / 문서
.git
.gitignore
.vscode
.idea
*.md

# 로그 / OS 잡파일
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.DS_Store

# 도커 관련 파일 자체 (런타임 스테이지가 쓰는 nginx.conf 는 제외하지 않음!)
Dockerfile
.dockerignore
