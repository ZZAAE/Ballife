# Ballife 프론트엔드 환경변수 예시
# 실제 값은 .env (git 미추적) 에 작성하세요.
#
# ⚠️ 하이브리드(Capacitor) 빌드 주의:
#   기기에서 "localhost" 는 기기 자신을 가리켜 개발 PC 백엔드에 닿지 않습니다.
#   반드시 LAN IP 또는 운영 도메인(가능하면 HTTPS)으로 지정하세요.
#   iOS ATS / Android cleartext 정책상 운영은 HTTPS 권장입니다.

# Spring 백엔드 REST API (끝에 /api 포함)
VITE_API_BASE_URL=http://localhost:8080/api

# FastAPI AI 서비스 (챗봇/분석)
VITE_AI_SERVICE_BASE_URL=http://localhost:8001

# (선택) 운동 API 를 별도 호스트로 분리할 때만
# VITE_EXERCISE_API_BASE_URL=http://localhost:8080/api
