# =============================================================================
# Ballife — application.yml 템플릿
# =============================================================================
# 사용법:
#   1) 이 파일을 같은 폴더에 application.yml 로 복사한다.
#   2) <YOUR_...> 플레이스홀더를 본인 환경 값으로 채운다.
#   3) application.yml 은 .gitignore 로 제외되어 있어서 커밋되지 않는다.
#      따라서 환경별 값(로컬 경로, 비밀번호 등)이 다른 팀원에게 새어 들어가지 않는다.
#
# 채워야 할 항목:
#   - storage.local.base-path : 본인 노트북의 이미지 임시 저장 폴더 경로
#
# 환경변수로 주입 가능한 항목 (선택):
#   - OPENAI_API_KEY    : OpenAI API 키
#   - MFDS_SERVICE_KEY  : 식약처 API 인증키
#   - FOOD_SAFETY_KEY   : 식약처 식품영양성분DB v2 인증키
# =============================================================================

spring:
  servlet:
    multipart:
      max-file-size: 10MB
      max-request-size: 10MB
  datasource:
    driver-class-name: com.mysql.cj.jdbc.Driver
    url: jdbc:mysql://localhost:3306/project_ballife?serverTimezone=Asia/Seoul
    username: ballife
    password: 1234
  jpa:
    hibernate:
      ddl-auto: update # 실서버에서는 validate로 설정해야 한다!
    show-sql: true
    properties:
      hibernate:
        dialect: org.hibernate.dialect.MySQL8Dialect
        format-sql: true

  data:
    mongodb:
      host: localhost #배포할때는 실제 서버 주소가 들어감
      port: 27017
      database: Ballife # 데이터베이스명

  security:
    jwt:
      secret: your-super-secret-key-that-is-at-least-64-bytes-long-for-hs512-to-work-correctly
      expiration: 86400000 #토큰 만료시간 (24시간 = 밀리초)

# CORS 허용 Origin (프론트엔드 주소). 콤마로 구분.
# 배포 시 환경변수로 실제 프론트 주소 주입: APP_CORS_ALLOWED_ORIGINS=https://your-frontend.com
app:
  cors:
    allowed-origins: ${APP_CORS_ALLOWED_ORIGINS:http://localhost:*,http://127.0.0.1:*}

openai:
  api-key: ${OPENAI_API_KEY:default}
  model: gpt-4o-mini # 모델버젼
  max-tokens: 1000 #응답 길이
  vision-detail: low

server:
  error:
    include-message: always
    include-binding-errors: always

logging:
  level:
    org.hibernate.SQL: debug #SQL 쿼리 로그 출력

springdoc:
  swagger-ui:
    path: /swagger-ui.html #API 문서 접속 경로
    enabled: true
    use-root-path: true
  api-docs:
    path: /v3/api-docs
  show-actuator: true

mfds:
  api:
    base-url: https://apis.data.go.kr/1471000/DrugPrdtPrmsnInfoService07
    service-key: ${MFDS_SERVICE_KEY:} # 환경변수로 주입 (절대 코드에 하드코딩 X). 미설정 시 빈 값으로 컨텍스트 로드 가능.

# 식약처 식품영양성분DB v2 (data.go.kr) — 음식 사진 분석 → 영양정보 조회
foodsafety:
  api:
    base-url: https://apis.data.go.kr/1471000/FoodNtrCpntDbInfo02
    operation: getFoodNtrCpntDbInq02 # v02 표준 작업명
    service-key: ${FOOD_SAFETY_KEY:} # data.go.kr 발급 인증키 (디코딩 키 권장)

# 음식 사진 등 업로드 파일 로컬 저장 경로
# - 운영 시 S3/CDN으로 교체 예정
# - 한글/공백 포함 경로는 forward slash + 따옴표 사용
storage:
  type: local
  local:
