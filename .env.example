# docker-compose 용 환경변수. 이 파일을 복사해 .env 로 만들고 값을 채운다.
#   cp .env.example .env
# .env 는 절대 깃에 올리지 말 것(비밀값 포함).

# ----- 이미지(레지스트리 배포 시) -----
# 로컬 빌드면 비워둬도 됨(기본 prefix=ballife). GitHub Actions 배포 시 자동 주입.
IMAGE_PREFIX=ghcr.io/<github-owner>
IMAGE_TAG=latest

# ----- 공개 포트 -----
FRONTEND_PORT=80

# ----- DB 자격증명 -----
MYSQL_USER=ballife
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-me-root

# ----- 보안 -----
# 최소 64바이트(HS512). 예: openssl rand -base64 64
JWT_SECRET=change-me-to-a-64-byte-or-longer-secret

# ----- 외부 API 키 -----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
MFDS_SERVICE_KEY=
FOOD_SAFETY_KEY=
NAVER_OCR_BASE_URL=
NAVER_OCR_SECRET_KEY=
