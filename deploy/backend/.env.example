# [backend-server] 용 .env
IMAGE_PREFIX=ghcr.io/<github-owner>
IMAGE_TAG=latest
# 의존 서버 주소
MYSQL_ADDR=<mysql서버IP>:3306
MONGO_HOST=<mongo서버IP>
MONGO_PORT=27017
AI_ADDR=<AI서버IP>:8001
# DB 자격증명 (mysql-server 의 값과 동일해야 함)
MYSQL_USER=ballife
MYSQL_PASSWORD=change-me
# 보안/외부 API
JWT_SECRET=change-me-to-a-64-byte-or-longer-secret
OPENAI_API_KEY=
MFDS_SERVICE_KEY=
FOOD_SAFETY_KEY=
NAVER_OCR_BASE_URL=
NAVER_OCR_SECRET_KEY=
